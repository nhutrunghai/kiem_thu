    {
      "name": "TC01 - Dang nhap thanh cong",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const expectedStatus = 200;",
              "const expectedMessage = \"\";",
              "const expectToken = true;",
              "const expectUser = true;",
              "const expectedUserEmail = \"newuser@example.com\";",
              "",
              "pm.test(\"[TC01] Dang nhap thanh cong - Status code is 200\", function () {",
              "  pm.response.to.have.status(expectedStatus);",
              "});",
              "",
              "let json = {};",
              "try {",
              "  json = pm.response.json();",
              "} catch (error) {",
              "  json = {};",
              "}",
              "",
              "if (expectedMessage) {",
              "  pm.test(\"[TC01] Dang nhap thanh cong - Message contains expected text\", function () {",
              "    const actualMessage = json.message || json.error || \"\";",
              "    pm.expect(actualMessage).to.include(expectedMessage);",
              "  });",
              "}",
              "",
              "if (expectToken) {",
              "  pm.test(\"[TC01] Dang nhap thanh cong - Response has token\", function () {",
              "    pm.expect(json.token).to.be.a(\"string\").and.not.empty;",
              "  });",
              "  if (json.token) {",
              "    pm.collectionVariables.set(\"token\", json.token);",
              "  }",
              "}",
              "",
              "if (expectUser) {",
              "  pm.test(\"[TC01] Dang nhap thanh cong - Response has user object\", function () {",
              "    pm.expect(json.user).to.be.an(\"object\");",
              "    pm.expect(json.user.email).to.eql(expectedUserEmail);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"12345678\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "TC01 - Dang nhap thanh cong. Body da co san, bam Send."
      },
      "response": []
