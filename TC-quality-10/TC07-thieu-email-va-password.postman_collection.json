      "name": "TC07 - Thieu ca email va password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const expectedStatus = 400;",
              "const expectedMessage = \"Missing required fields\";",
              "const expectToken = false;",
              "const expectUser = false;",
              "const expectedUserEmail = \"\";",
              "",
              "pm.test(\"[TC07] Thieu ca email va password - Status code is 400\", function () {",
              "  pm.response.to.have.status(expectedStatus);",
              "});",
              "",
              "let json = {};",
              "try {",
              "  json = pm.response.json();",
              "} catch (error) {",
              "  json = {};",
              "}",
              "",
              "if (expectedMessage) {",
              "  pm.test(\"[TC07] Thieu ca email va password - Message contains expected text\", function () {",
              "    const actualMessage = json.message || json.error || \"\";",
              "    pm.expect(actualMessage).to.include(expectedMessage);",
              "  });",
              "}",
              "",
              "if (expectToken) {",
              "  pm.test(\"[TC07] Thieu ca email va password - Response has token\", function () {",
              "    pm.expect(json.token).to.be.a(\"string\").and.not.empty;",
              "  });",
              "  if (json.token) {",
              "    pm.collectionVariables.set(\"token\", json.token);",
              "  }",
              "} else {",
              "  pm.test(\"[TC07] Thieu ca email va password - Response does not include token\", function () {",
              "    pm.expect(json.token).to.be.undefined;",
              "  });",
              "}",
              "",
              "if (expectUser) {",
              "  pm.test(\"[TC07] Thieu ca email va password - Response has user object\", function () {",
              "    pm.expect(json.user).to.be.an(\"object\");",
              "    pm.expect(json.user.email).to.be.a(\"string\").and.not.empty;",
              "  });",
              "} else {",
              "  pm.test(\"[TC07] Thieu ca email va password - Response does not include user object\", function () {",
              "    pm.expect(json.user).to.be.undefined;",
              "  });",
              "}",
              "",
              "if (expectedUserEmail) {",
              "  pm.test(\"[TC07] Thieu ca email va password - User email is normalized\", function () {",
              "    pm.expect(json.user.email).to.eql(expectedUserEmail);",
              "  });",
              "}"
            ]
          }
        }
      ],
